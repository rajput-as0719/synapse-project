					},
					"a365ComputeOptions": {
						"id": "/subscriptions/63e66dd7-d522-404c-b35b-f557c7f8143c/resourceGroups/ecommerce_analytics/providers/Microsoft.Synapse/workspaces/synapse-ecom-analytics-dev/bigDataPools/sparkpool",
						"name": "sparkpool",
						"type": "Spark",
						"endpoint": "https://synapse-ecom-analytics-dev.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/sparkpool",
						"auth": {
							"type": "AAD",
							"authResource": "https://dev.azuresynapse.net"
						},
						"sparkVersion": "3.5",
						"nodeCount": 3,
						"cores": 8,
						"memory": 56,
						"automaticScaleJobs": true
					},
					"sessionKeepAliveTimeout": 30
				},
				"cells": [
					{
						"cell_type": "code",
						"metadata": {},
						"source": [
							"from pyspark.sql.functions import *\n",
							"from pyspark.sql.types import *\n",
							"\n",
							"source_container = \"retail-data\"\n",
							"source_folders = \"customers\"\n",
							"target_container = \"bronze\"\n",
							"target_folders = \"customers\"\n",
							"\n",
							"print (f\"Data processing started {source_folders}\")\n",
							"\n",
							"df = spark.read.format(\"csv\")\\\n",
							"        .option(\"header\",\"true\")\\\n",
							"        .option(\"inferSchema\",\"true\")\\\n",
							"        .load(f\"abfss://{source_container}@ecomdevstorage1.dfs.core.windows.net/{source_folders}/*\")\n",
							"    \n",
							"print(f\"Read completed for {source_folders} in {source_container} container. Now adding tow metadata columns to {source_folders}.\")\n",
							"\n",
							"df = df\\\n",
							"        .withColumn(\"file_path\", input_file_name())\\\n",
							"        .withColumn(\"last_updated_ts\", current_timestamp())\n",
							"    \n",
							"print(f\"Metadata columns added successfully. Now writing {target_folders} to {target_container} container.\")\n",
							"\n",
							"df.write\\\n",
							"    .format(\"delta\")\\\n",
							"    .mode(\"overwrite\")\\\n",
							"    .save(f\"abfss://{target_container}@ecomdevstorage1.dfs.core.windows.net/{target_folders}/\")\n",
							"    \n",
							"print(f\"Write completed for {target_folders} in {target_container} container.\")\n",
							"\n",
							"print(f\"Data processing completed successfully all {target_folders} in {target_container}\")"
						],
						"outputs": [],
						"execution_count": null
					}
				]
			},
			"dependsOn": []

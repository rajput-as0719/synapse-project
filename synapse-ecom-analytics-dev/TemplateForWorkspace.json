				},
				"metadata": {
					"saveOutput": true,
					"enableDebugMode": false,
					"kernelspec": {
						"name": "synapse_pyspark",
						"display_name": "Synapse PySpark"
					},
					"language_info": {
						"name": "python"
					},
					"a365ComputeOptions": {
						"id": "/subscriptions/63e66dd7-d522-404c-b35b-f557c7f8143c/resourceGroups/ecommerce_analytics/providers/Microsoft.Synapse/workspaces/synapse-ecom-analytics-dev/bigDataPools/sparkpool",
						"name": "sparkpool",
						"type": "Spark",
						"endpoint": "https://synapse-ecom-analytics-dev.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/sparkpool",
						"auth": {
							"type": "AAD",
							"authResource": "https://dev.azuresynapse.net"
						},
						"sparkVersion": "3.5",
						"nodeCount": 3,
						"cores": 8,
						"memory": 56,
						"automaticScaleJobs": true
					},
					"sessionKeepAliveTimeout": 30
				},
				"cells": [
					{
						"cell_type": "code",
						"metadata": {},
						"source": [
							"from pyspark.sql.functions import *\n",
							"from pyspark.sql.types import *\n",
							"\n",
							"source_container = \"retail-data\"\n",
							"target_container = \"bronze\"\n",
							"entities = [\"customers\",\"sales\",\"sales_orders\"]\n",
							"\n",
							"def add_metadata_columns(df):\n",
							"    df = df\\\n",
							"        .withColumn(\"file_path\", input_file_name())\\\n",
							"        .withColumn(\"last_updated_ts\", current_timestamp())\n",
							"    return df\n",
							"\n",
							"for entity in entities:\n",
							"    print (f\"Data processing started for entity: {entity}\")\n",
							"\n",
							"    df = spark.read.format(\"csv\")\\\n",
							"        .option(\"header\",\"true\")\\\n",
							"        .option(\"inferSchema\",\"true\")\\\n",
							"        .load(f\"abfss://{source_container}@ecomdevstorage1.dfs.core.windows.net/{entity}/*\")\n",
							"    \n",
							"    print(f\"Read completed for {entity} in {source_container} container. Now adding tow metadata columns to {entity}.\")\n",
							"\n",
							"    df = add_metadata_columns(df)\n",
							"    \n",
							"    print(f\"Metadata columns added successfully. Now writing {entity} to {target_container} container.\")\n",
							"\n",
							"    df.write\\\n",
							"        .format(\"delta\")\\\n",
							"        .mode(\"overwrite\")\\\n",
							"        .save(f\"abfss://{target_container}@ecomdevstorage1.dfs.core.windows.net/{entity}/\")\n",
							"    \n",
							"    print(f\"Write completed for {entity} in {target_container} container.\")\n",
							"\n",
							"print(f\"Data processing completed successfully for all entities: {entities}\")"
						],
						"outputs": [],
						"execution_count": null
					}
				]
			},
			"dependsOn": []
		},

{
	"name": "pl_metadata_driven_via_sql",
	"properties": {
		"activities": [
			{
				"name": "LookupMetadata",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "SqlServerMetaTable",
						"type": "DatasetReference"
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "ForEachRowInTable",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "LookupMetadata",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('LookupMetadata').output.value",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "metadata_driven_pl_notebook",
							"type": "SynapseNotebook",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"notebook": {
									"referenceName": "nb_bronze_ingestion_pl_driven",
									"type": "NotebookReference"
								},
								"parameters": {
									"source_container": {
										"value": {
											"value": "@item().source_container",
											"type": "Expression"
										},
										"type": "string"
									},
									"source_folders": {
										"value": {
											"value": "@item().source_folders",
											"type": "Expression"
										},
										"type": "string"
									},
									"target_container": {
										"value": {
											"value": "@item().target_container",
											"type": "Expression"
										},
										"type": "string"
									},
									"target_folders": {
										"value": {
											"value": "@item().target_folders",
											"type": "Expression"
										},
										"type": "string"
									}
								},
								"snapshot": true,
								"sparkPool": {
									"referenceName": "sparkpool",
									"type": "BigDataPoolReference"
								},
								"executorSize": "Small",
								"conf": {
									"spark.dynamicAllocation.enabled": true
								},
								"driverSize": "Small"
							}
						}
					]
				}
			}
		],
		"annotations": []
	}
}
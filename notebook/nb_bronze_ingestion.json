				"source": [
					"from pyspark.sql.functions import *\n",
					"from pyspark.sql.types import *\n",
					"\n",
					"customers_df = spark.read.format(\"csv\")\\\n",
					"    .option(\"header\",\"true\")\\\n",
					"    .option(\"inferSchema\",\"true\")\\\n",
					"    .load(\"abfss://retail-data@ecomdevstorage1.dfs.core.windows.net/customers/*\")\n",
					"\n",
					"display(customers_df)"
				],
				"execution_count": 8
			},
			{
				"cell_type": "code",
				"metadata": {
					"collapsed": false
				},
				"source": [
					"bronze_df = customers_df\\\n",
					"    .withColumn(\"file_path\", input_file_name())\\\n",
					"    .withColumn(\"last_updated_ts\", current_timestamp())\n",
					"\n",
					"display(bronze_df)"
				],
				"execution_count": 9
			},
			{
				"cell_type": "code",
				"source": [
					"bronze_df.write\\\n",
					"    .format(\"delta\")\\\n",
					"    .mode(\"overwrite\")\\\n",
					"    .save(\"abfss://bronze@ecomdevstorage1.dfs.core.windows.net/customers/\")"
				],
				"execution_count": 11
			}
